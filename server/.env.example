# ──────────────────────────────────────────────────────────────────────────
#  FineLine payments — environment configuration
#
#  1. Copy this file to ".env"  ->  cp .env.example .env
#  2. Paste your PayPal credentials below (see PAYPAL_INTEGRATION.md, point 7).
#  3. NEVER commit ".env" — it is already in .gitignore.
#
#  Get the keys from: https://developer.paypal.com/dashboard/applications
#    Sandbox tab (testing) or Live tab (production) -> your App -> API credentials
# ──────────────────────────────────────────────────────────────────────────

# "sandbox" while testing, "live" in production.
PAYPAL_ENV=sandbox

# ⬇️  PASTE YOUR KEYS HERE — these stay on the server and are never sent to the browser.
PAYPAL_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=PASTE_YOUR_SECRET_KEY_HERE

# Webhook id from: Developer Dashboard -> your App -> Webhooks (after you create one).
PAYPAL_WEBHOOK_ID=PASTE_YOUR_WEBHOOK_ID_HERE

# The ONLY origin allowed to call this API (your frontend). No trailing slash.
CLIENT_ORIGIN=http://localhost:5173

# Long random string used to sign CSRF tokens & cookies.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=replace_with_a_long_random_secret
COOKIE_SECRET=replace_with_another_long_random_secret

# Server port.
PORT=4000

# Set to "true" only when served over HTTPS (production) so cookies become Secure.
SECURE_COOKIES=false
